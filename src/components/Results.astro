---
import { badge } from '../lib/hyperui';

interface Props {
  estimate: number;
  knownCount: number;
  totalCount: number;
  level: string;
  feedback: string;
}

const { estimate, knownCount, totalCount, level, feedback } = Astro.props;
const formatted = estimate.toLocaleString('en-US');
---

<div class="text-center">
  <p class="text-xs font-medium tracking-wide text-gray-700 uppercase">
    Estimated vocabulary
  </p>
  <p class="mt-2 text-5xl font-bold text-gray-900 sm:text-6xl">
    {formatted}
  </p>
  <p class="mt-1 text-lg text-gray-500">words</p>

  <div class="mt-6">
    <span class={badge}>{level}</span>
  </div>

  <p class="mt-6 text-left text-sm text-gray-700 leading-relaxed">
    {feedback}
  </p>

  <p class="mt-4 text-xs text-gray-500">
    You marked {knownCount} of {totalCount} words as known.
  </p>
</div>