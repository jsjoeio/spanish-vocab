---
import { btnFlag, btnNo, btnPrimary, btnQuiet, btnSecondary, btnYes, card } from '../lib/hyperui';
---

<div id="vocab-test" class="mx-auto w-full max-w-lg">
  <!-- Intro screen -->
  <div id="screen-intro" class="text-center">
    <h1 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">
      Spanish Vocabulary Test
    </h1>
    <p class="mt-4 text-sm text-gray-700 leading-relaxed">
      You'll see up to 50 Spanish words sampled across frequency bands from a
      specific word list. We use your answers to estimate how many lemmas from
      that list you know — <strong>not</strong> your entire Spanish vocabulary.
      Click <strong>Yes</strong> only if you can recall the meaning, not just
      recognize the word.
    </p>
    <p id="source-label" class="mt-2 text-xs text-gray-500"></p>
    <button id="btn-start" type="button" class:list={['mt-8', btnPrimary]}>
      Start test
    </button>
  </div>

  <!-- Test screen -->
  <div id="screen-test" class="hidden">
    <div id="progress-container" class="mb-8"></div>

    <div class={card}>
      <p class="text-sm font-medium text-gray-700">Do you know this word?</p>
      <p id="current-word" class="mt-3 text-4xl font-bold text-gray-900 sm:text-5xl"></p>

      <div class="mt-8 grid grid-cols-2 gap-3">
        <button id="btn-no" type="button" class={btnNo}>No</button>
        <button id="btn-yes" type="button" class={btnYes}>Yes</button>
      </div>

      <div id="dev-flag-area" class="mt-4 hidden">
        <button id="btn-flag" type="button" class={btnFlag}>🚩 Flag</button>
      </div>
    </div>

    <button id="btn-finish" type="button" class:list={['mt-6', btnQuiet]}>
      Finish early
    </button>
  </div>

  <!-- Results screen -->
  <div id="screen-results" class="hidden">
    <div class={card}>
      <div id="results-content"></div>
    </div>
    <div class="mt-6 flex flex-col items-center gap-3 sm:flex-row sm:justify-center">
      <button id="btn-restart" type="button" class={btnSecondary}>
        Take test again
      </button>
      <button id="btn-copy-incorrect" type="button" class:list={['hidden', btnSecondary]} data-original-text="Copy unknown lemmas">
        Copy unknown lemmas
      </button>
      <button id="btn-copy-flagged" type="button" class:list={['hidden', btnSecondary]} data-original-text="Copy flagged lemmas">
        Copy flagged lemmas
      </button>
    </div>
  </div>
</div>

<script>
  import { buildTest, estimateVocabulary, type TestWord } from '../lib/algorithm';
  import { btnFlag as btnFlagCss, btnFlagActive as btnFlagActiveCss, progressBarHtml, resultsHtml } from '../lib/hyperui';
  import { defaultSource, type FrequencyListData } from '../lib/sources';

  const screens = {
    intro: document.getElementById('screen-intro')!,
    test: document.getElementById('screen-test')!,
    results: document.getElementById('screen-results')!,
  };

  const btnStart = document.getElementById('btn-start') as HTMLButtonElement;
  const btnCopyIncorrect = document.getElementById('btn-copy-incorrect') as HTMLButtonElement;
  const btnCopyFlagged = document.getElementById('btn-copy-flagged') as HTMLButtonElement;
  const devFlagArea = document.getElementById('dev-flag-area')!;
  const btnFlag = document.getElementById('btn-flag') as HTMLButtonElement;
  const sourceLabel = document.getElementById('source-label')!;
  const currentWord = document.getElementById('current-word')!;
  const progressContainer = document.getElementById('progress-container')!;
  const resultsContent = document.getElementById('results-content')!;

  const isDev = new URLSearchParams(window.location.search).get('isDev') === 'true';

  if (isDev) {
    devFlagArea.classList.remove('hidden');
  }

  let testWords: TestWord[] = [];
  let sourceData: FrequencyListData | null = null;
  let currentIndex = 0;
  let answers: boolean[] = [];
  let flaggedLemmas = new Set<string>();

  sourceLabel.textContent = `Source: ${defaultSource.name}`;

  function isValidSourceData(data: unknown): data is FrequencyListData {
    if (!data || typeof data !== 'object') return false;
    const record = data as FrequencyListData;
    return (
      Array.isArray(record.lemmas) &&
      record.lemmas.length > 0 &&
      record.lemmas.every(
        (l) => typeof l.lemma === 'string' && typeof l.frequency === 'number'
      )
    );
  }

  function showScreen(name: keyof typeof screens) {
    Object.values(screens).forEach((el) => el.classList.add('hidden'));
    screens[name].classList.remove('hidden');
  }

  function updateFlagBtn(flagged: boolean) {
    if (flagged) {
      btnFlag.textContent = '✓ Flagged';
      btnFlag.className = btnFlagActiveCss;
    } else {
      btnFlag.textContent = '🚩 Flag';
      btnFlag.className = btnFlagCss;
    }
  }

  function renderWord() {
    const word = testWords[currentIndex];
    currentWord.textContent = word.lemma;
    progressContainer.innerHTML = progressBarHtml(answers.length, testWords.length);
    if (isDev) {
      updateFlagBtn(flaggedLemmas.has(word.lemma));
    }
  }

  function renderResults() {
    const testedWords = testWords.slice(0, answers.length);
    const result = estimateVocabulary(
      testedWords,
      answers,
      sourceData!.lemmas.length
    );

    resultsContent.innerHTML = resultsHtml(
      result.estimate,
      result.low,
      result.high,
      result.level,
      result.cefr,
      result.feedback,
      result.knownCount,
      result.totalCount,
      result.sourceSize,
      sourceData!.name,
      result.coveragePercent
    );

    const unknownLemmas = testedWords
      .filter((_, i) => answers[i] !== true)
      .map((w) => w.lemma);

    if (unknownLemmas.length > 0) {
      btnCopyIncorrect.classList.remove('hidden');
      btnCopyIncorrect.dataset.lemmas = unknownLemmas.join('\n');
    } else {
      btnCopyIncorrect.classList.add('hidden');
      delete btnCopyIncorrect.dataset.lemmas;
    }

    if (isDev && flaggedLemmas.size > 0) {
      btnCopyFlagged.classList.remove('hidden');
      btnCopyFlagged.dataset.lemmas = [...flaggedLemmas].join('\n');
    } else {
      btnCopyFlagged.classList.add('hidden');
      delete btnCopyFlagged.dataset.lemmas;
    }
  }

  function answer(known: boolean) {
    answers.push(known);
    currentIndex++;

    if (currentIndex >= testWords.length) {
      renderResults();
      showScreen('results');
      return;
    }

    renderWord();
  }

  async function startTest() {
    btnStart.disabled = true;
    btnStart.textContent = 'Loading…';

    try {
      // side effect: fetch frequency list at runtime (keeps bundle small, supports future multi-source)
      const dataUrl = `${import.meta.env.BASE_URL}${defaultSource.dataPath}`;
      const res = await fetch(dataUrl);
      if (!res.ok) throw new Error(`failed to load frequency list (${res.status})`);
      const data: unknown = await res.json();
      if (!isValidSourceData(data)) {
        throw new Error('invalid or empty frequency list');
      }
      sourceData = data;

      testWords = buildTest(sourceData.lemmas);
      if (testWords.length === 0) {
        throw new Error('no test words could be sampled from frequency list');
      }

      currentIndex = 0;
      answers = [];
      renderWord();
      showScreen('test');
    } catch (err) {
      btnStart.textContent = 'Failed — try again';
      console.error(err);
    } finally {
      btnStart.disabled = false;
      if (btnStart.textContent === 'Loading…') {
        btnStart.textContent = 'Start test';
      }
    }
  }

  function finishEarly() {
    if (answers.length === 0) return;
    renderResults();
    showScreen('results');
  }

  function restart() {
    flaggedLemmas = new Set();
    btnStart.textContent = 'Start test';
    showScreen('intro');
  }

  function toggleFlag() {
    const lemma = testWords[currentIndex].lemma;
    if (flaggedLemmas.has(lemma)) {
      flaggedLemmas.delete(lemma);
      updateFlagBtn(false);
    } else {
      flaggedLemmas.add(lemma);
      updateFlagBtn(true);
    }
  }

  let copyTimeout: ReturnType<typeof setTimeout> | null = null;
  let copyFlaggedTimeout: ReturnType<typeof setTimeout> | null = null;

  async function copyIncorrectLemmas() {
    const lemmas = btnCopyIncorrect.dataset.lemmas;
    if (!lemmas) return;
    const text = lemmas
      .split('\n')
      .map((l) => `- ${l}`)
      .join('\n');
    try {
      await navigator.clipboard.writeText(text);
      const original = btnCopyIncorrect.dataset.originalText ?? 'Copy unknown lemmas';
      if (copyTimeout !== null) clearTimeout(copyTimeout);
      btnCopyIncorrect.textContent = 'Copied!';
      copyTimeout = setTimeout(() => {
        btnCopyIncorrect.textContent = original;
        copyTimeout = null;
      }, 2000);
    } catch {
      // silently ignore clipboard errors (e.g. in non-secure contexts)
    }
  }

  async function copyFlaggedLemmas() {
    const lemmas = btnCopyFlagged.dataset.lemmas;
    if (!lemmas) return;
    const text = lemmas
      .split('\n')
      .map((l) => `- ${l}`)
      .join('\n');
    try {
      await navigator.clipboard.writeText(text);
      const original = btnCopyFlagged.dataset.originalText ?? 'Copy flagged lemmas';
      if (copyFlaggedTimeout !== null) clearTimeout(copyFlaggedTimeout);
      btnCopyFlagged.textContent = 'Copied!';
      copyFlaggedTimeout = setTimeout(() => {
        btnCopyFlagged.textContent = original;
        copyFlaggedTimeout = null;
      }, 2000);
    } catch {
      // silently ignore clipboard errors (e.g. in non-secure contexts)
    }
  }

  btnStart.addEventListener('click', startTest);
  document.getElementById('btn-yes')!.addEventListener('click', () => answer(true));
  document.getElementById('btn-no')!.addEventListener('click', () => answer(false));
  document.getElementById('btn-finish')!.addEventListener('click', finishEarly);
  document.getElementById('btn-restart')!.addEventListener('click', restart);
  btnCopyIncorrect.addEventListener('click', copyIncorrectLemmas);
  btnFlag.addEventListener('click', toggleFlag);
  btnCopyFlagged.addEventListener('click', copyFlaggedLemmas);
</script>