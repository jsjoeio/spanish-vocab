<div id="vocab-test" class="mx-auto w-full max-w-lg">
  <!-- Intro screen -->
  <div id="screen-intro" class="text-center">
    <h1 class="text-3xl font-bold tracking-tight text-stone-900 sm:text-4xl">
      Spanish Vocabulary Test
    </h1>
    <p class="mt-4 text-stone-600 leading-relaxed">
      You'll see 50 Spanish words. Mark each one <strong>Yes</strong> if you know
      its meaning, or <strong>No</strong> if you don't. Be honest — it improves the estimate.
    </p>
    <button
      id="btn-start"
      type="button"
      class="mt-8 w-full rounded-xl bg-amber-500 px-6 py-3.5 text-base font-semibold text-white shadow-sm transition hover:bg-amber-600 active:scale-[0.98] sm:w-auto"
    >
      Start test
    </button>
  </div>

  <!-- Test screen -->
  <div id="screen-test" class="hidden">
    <div id="progress-container" class="mb-8"></div>

    <div class="rounded-2xl border border-stone-200 bg-white p-8 shadow-sm">
      <p class="text-sm font-medium text-stone-500">Do you know this word?</p>
      <p id="current-word" class="mt-3 text-4xl font-bold text-stone-900 sm:text-5xl"></p>

      <div class="mt-8 grid grid-cols-2 gap-3">
        <button
          id="btn-no"
          type="button"
          class="rounded-xl border-2 border-stone-200 bg-white px-4 py-4 text-lg font-semibold text-stone-700 transition hover:border-stone-300 hover:bg-stone-50 active:scale-[0.98]"
        >
          No
        </button>
        <button
          id="btn-yes"
          type="button"
          class="rounded-xl bg-amber-500 px-4 py-4 text-lg font-semibold text-white transition hover:bg-amber-600 active:scale-[0.98]"
        >
          Yes
        </button>
      </div>
    </div>

    <button
      id="btn-finish"
      type="button"
      class="mt-6 w-full text-sm font-medium text-stone-400 transition hover:text-stone-600"
    >
      Finish early
    </button>
  </div>

  <!-- Results screen -->
  <div id="screen-results" class="hidden">
    <div class="rounded-2xl border border-stone-200 bg-white p-8 shadow-sm">
      <div id="results-content"></div>
    </div>
    <button
      id="btn-restart"
      type="button"
      class="mt-6 w-full rounded-xl border-2 border-stone-200 bg-white px-6 py-3.5 text-base font-semibold text-stone-700 transition hover:border-stone-300 hover:bg-stone-50 active:scale-[0.98]"
    >
      Take test again
    </button>
  </div>
</div>

<script>
  import words from '../data/words.json';
  import { estimateVocabulary } from '../lib/estimate';

  const screens = {
    intro: document.getElementById('screen-intro')!,
    test: document.getElementById('screen-test')!,
    results: document.getElementById('screen-results')!,
  };

  const currentWord = document.getElementById('current-word')!;
  const progressContainer = document.getElementById('progress-container')!;
  const resultsContent = document.getElementById('results-content')!;

  let currentIndex = 0;
  let answers: boolean[] = [];

  function showScreen(name: keyof typeof screens) {
    Object.values(screens).forEach((el) => el.classList.add('hidden'));
    screens[name].classList.remove('hidden');
  }

  function renderProgress() {
    const answered = answers.length;
    const total = words.length;
    const percent = Math.round((answered / total) * 100);

    progressContainer.innerHTML = `
      <div class="w-full">
        <div class="mb-2 flex justify-between text-sm text-stone-500">
          <span>Progress</span>
          <span>${answered} / ${total}</span>
        </div>
        <div class="h-2 w-full overflow-hidden rounded-full bg-stone-200">
          <div
            class="h-full rounded-full bg-amber-500 transition-all duration-300"
            style="width: ${percent}%"
            role="progressbar"
            aria-valuenow="${answered}"
            aria-valuemin="0"
            aria-valuemax="${total}"
          ></div>
        </div>
      </div>
    `;
  }

  function renderWord() {
    currentWord.textContent = words[currentIndex].word;
    renderProgress();
  }

  function renderResults() {
    const testedWords = words.slice(0, answers.length);
    const result = estimateVocabulary(testedWords, answers);
    const formatted = result.estimate.toLocaleString('en-US');

    resultsContent.innerHTML = `
      <div class="text-center">
        <p class="text-sm font-medium uppercase tracking-wide text-stone-500">
          Estimated vocabulary
        </p>
        <p class="mt-2 text-5xl font-bold text-stone-900 sm:text-6xl">${formatted}</p>
        <p class="mt-1 text-lg text-stone-500">words</p>
        <div class="mt-6 inline-block rounded-full bg-amber-100 px-4 py-1.5 text-sm font-semibold text-amber-800">
          ${result.level}
        </div>
        <p class="mt-6 text-left text-stone-600 leading-relaxed">${result.feedback}</p>
        <p class="mt-4 text-sm text-stone-400">
          You marked ${result.knownCount} of ${result.totalCount} words as known.
        </p>
      </div>
    `;
  }

  function answer(known: boolean) {
    answers.push(known);
    currentIndex++;

    if (currentIndex >= words.length) {
      renderResults();
      showScreen('results');
      return;
    }

    renderWord();
  }

  function startTest() {
    currentIndex = 0;
    answers = [];
    renderWord();
    showScreen('test');
  }

  function finishEarly() {
    if (answers.length === 0) return;
    renderResults();
    showScreen('results');
  }

  document.getElementById('btn-start')!.addEventListener('click', startTest);
  document.getElementById('btn-yes')!.addEventListener('click', () => answer(true));
  document.getElementById('btn-no')!.addEventListener('click', () => answer(false));
  document.getElementById('btn-finish')!.addEventListener('click', finishEarly);
  document.getElementById('btn-restart')!.addEventListener('click', () => {
    showScreen('intro');
  });
</script>